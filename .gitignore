# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# environment variables (secrets / API keys)
.env
.env*.local

# dependencies
node_modules/
/.pnp
.pnp.js

# build output
/client/dist/
/build
/.next/
/out/

# cached / generated data
/server/data/

# logs
*.log
output.log
/server/output.log
/server/test-output.txt

# debug & temporary state files
/server/state-debug.json
/server/state-output.json

# one-off debug / test scripts (not part of the app)
/server/debug-agent.js
/server/inspect-state.js
/server/inspect-state-new.js
/server/test.js
/server/test_models.js
/server/test-*.js

# testing coverage
/coverage

# misc
.DS_Store
*.pem
Thumbs.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
